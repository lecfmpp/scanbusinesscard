# Netlify response headers.
# ---------------------------------------------------------------------------
# RFC 8288 Link headers for agent discovery, served on the homepage.
# They advertise the API catalog, the OpenAPI service description, the
# human/agent docs, and the llms.txt describedby resource.
/
  Link: </.well-known/api-catalog>; rel="api-catalog"; type="application/linkset+json", </.well-known/openapi.json>; rel="service-desc"; type="application/json", </auth.md>; rel="service-doc"; type="text/markdown", </llms.txt>; rel="describedby"; type="text/plain"
  X-Content-Type-Options: nosniff
/index.html
  Link: </.well-known/api-catalog>; rel="api-catalog"; type="application/linkset+json", </.well-known/openapi.json>; rel="service-desc"; type="application/json", </auth.md>; rel="service-doc"; type="text/markdown", </llms.txt>; rel="describedby"; type="text/plain"

